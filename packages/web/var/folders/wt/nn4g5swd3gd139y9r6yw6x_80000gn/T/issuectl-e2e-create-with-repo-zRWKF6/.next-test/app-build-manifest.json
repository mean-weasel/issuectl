{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/error": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/error.css",
      "static/chunks/app/error.js"
    ],
    "/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/loading.css",
      "static/chunks/app/loading.js"
    ],
    "/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/not-found.css",
      "static/chunks/app/not-found.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/page.css",
      "static/chunks/app/page.js"
    ],
    "/issues/[owner]/[repo]/[number]/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/issues/[owner]/[repo]/[number]/loading.css",
      "static/chunks/app/issues/[owner]/[repo]/[number]/loading.js"
    ],
    "/issues/[owner]/[repo]/[number]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/issues/[owner]/[repo]/[number]/page.css",
      "static/chunks/app/issues/[owner]/[repo]/[number]/page.js"
    ],
    "/drafts/[draftId]/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/drafts/[draftId]/loading.css",
      "static/chunks/app/drafts/[draftId]/loading.js"
    ],
    "/drafts/[draftId]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/drafts/[draftId]/page.css",
      "static/chunks/app/drafts/[draftId]/page.js"
    ]
  }
}